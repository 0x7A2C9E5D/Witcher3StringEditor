<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iwk="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:c="clr-namespace:Witcher3StringEditor.Dialogs.Converters"
    xmlns:l="clr-namespace:Witcher3StringEditor.Locales;assembly=Witcher3StringEditor.Locales"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:Witcher3StringEditor.Dialogs.ViewModels">
    <!-- 
        Data template for single item translation view
        This template is used to display the UI for single item translation operations
        Binds to SingleItemTranslationViewModel for data and command binding
    -->
    <DataTemplate x:Key="TranslateDataTemplate" DataType="{x:Type vm:SingleItemTranslationViewModel}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Language selection combobox row -->
                <RowDefinition Height="Auto" />
                <!-- Spacing row -->
                <RowDefinition Height="16" />
                <!-- Text content textbox row -->
                <RowDefinition Height="*" />
                <!-- Spacing row -->
                <RowDefinition Height="24" />
                <!-- Action buttons row -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- Source text column -->
                <ColumnDefinition Width="*" />
                <!-- Spacing column -->
                <ColumnDefinition Width="16" />
                <!-- Translated text column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Source language selection combobox -->
            <ComboBox
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="NativeName"
                ui:ControlHelper.Header="{I18N {x:Static l:LangKeys.SrcTxt}}"
                ItemsSource="{Binding Languages}"
                SelectedValue="{Binding FormLanguage, Mode=TwoWay}" />
            <!-- Source text content display -->
            <TextBox
                Grid.Row="2"
                Grid.Column="0"
                IsReadOnly="True"
                Text="{Binding CurrentTranslateItemModel.Text, FallbackValue=''}"
                TextWrapping="WrapWithOverflow" />
            <!-- Target language selection combobox -->
            <ComboBox
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="NativeName"
                ui:ControlHelper.Header="{I18N {x:Static l:LangKeys.TranslatedTxt}}"
                ItemsSource="{Binding Languages}"
                SelectedValue="{Binding ToLanguage, Mode=TwoWay}" />
            <!-- Translated text input field -->
            <TextBox
                Grid.Row="2"
                Grid.Column="2"
                IsReadOnly="{Binding IsBusy}"
                Text="{Binding CurrentTranslateItemModel.TranslatedText, FallbackValue=''}"
                TextWrapping="WrapWithOverflow">
                <TextBox.Resources>
                    <c:LangKeyToStringConverter x:Key="LangKeyToStringConverter" />
                </TextBox.Resources>
                <TextBox.Style>
                    <!-- ReSharper disable once Xaml.StaticResourceNotResolved -->
                    <Style BasedOn="{StaticResource DefaultTextBoxStyle}" TargetType="TextBox">
                        <!-- Default placeholder text -->
                        <Setter Property="ui:ControlHelper.PlaceholderText" Value="" />
                        <Style.Triggers>
                            <!-- Show "Translating..." placeholder when translation is in progress -->
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="ui:ControlHelper.PlaceholderText"
                                        Value="{Binding Source={x:Static l:LangKeys.Translating} ,Converter={StaticResource LangKeyToStringConverter}}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <!-- Action buttons for navigation, translation, and saving -->
            <iwk:SimpleStackPanel
                Grid.Row="4"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="16">
                <!-- Previous item button -->
                <Button
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Command="{Binding PreviousCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Previous}" />
                        <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.PreviousBtnContent}}" />
                    </StackPanel>
                </Button>
                <!-- Translate button -->
                <Button
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Command="{Binding TranslateCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.LocaleLanguage}" />
                        <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.TranslateBtnContent}}" />
                    </StackPanel>
                </Button>
                <!-- Save translation button -->
                <Button
                    MinWidth="100"
                    HorizontalAlignment="Left"
                    Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Save}" />
                        <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.SaveBtnContent}}" />
                    </StackPanel>
                </Button>
                <!-- Next item button -->
                <Button
                    MinWidth="100"
                    HorizontalAlignment="Left"
                    Command="{Binding NextCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Next}" />
                        <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.NextBtnContent}}" />
                    </StackPanel>
                </Button>
            </iwk:SimpleStackPanel>
        </Grid>
    </DataTemplate>
</ResourceDictionary>