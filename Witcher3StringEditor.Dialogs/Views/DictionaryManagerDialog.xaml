<Window x:Class="Witcher3StringEditor.Dialogs.Views.DictionaryManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:Witcher3StringEditor.Dialogs.ViewModels"
        xmlns:sf="http://schemas.syncfusion.com/wpf"
        xmlns:l="clr-namespace:Witcher3StringEditor.Locales;assembly=Witcher3StringEditor.Locales"
        xmlns:m="clr-namespace:Witcher3StringEditor.Dialogs.Models"
        xmlns:s="clr-namespace:System;assembly=mscorlib"
        xmlns:t="clr-namespace:Witcher3StringEditor.Dialogs.TemplateSelectors"
        xmlns:c="clr-namespace:Witcher3StringEditor.Dialogs.Converters"
        xmlns:b="clr-namespace:Witcher3StringEditor.Dialogs.Behaviors"
        d:DataContext="{d:DesignInstance Type=vm:DictionaryManagerDialogViewModel}"
        Title="{I18N {x:Static l:LangKeys.DictionaryDialogTitle}}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        Closed="DictionaryDialog_OnClosed"
        mc:Ignorable="d" Width="1200" Height="800">
    <Window.Resources>
        <c:PathToDisplayNameConverter x:Key="PathToDisplayNameConverter" />
        <HierarchicalDataTemplate x:Key="DictionaryGroupTemplate" DataType="{x:Type m:DictionaryGroup}"
                                  ItemsSource="{Binding DictionaryNames}">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Folder}" />
                <TextBlock Margin="5,0,0,0" Text="{Binding TargetLanguage.NativeName}" />
            </StackPanel>
        </HierarchicalDataTemplate>
        <DataTemplate x:Key="DictionaryItemTemplate" DataType="{x:Type s:String}">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Document}" />
                <TextBlock Margin="5,0,0,0" Text="{Binding Converter={StaticResource PathToDisplayNameConverter}}" />
            </StackPanel>
        </DataTemplate>
        <t:DictionaryTreeTemplateSelector x:Key="DictionaryTreeTemplateSelector"
                                          DictionaryGroupTemplate="{StaticResource DictionaryGroupTemplate}"
                                          DictionaryItemTemplate="{StaticResource DictionaryItemTemplate}" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Height="48" Grid.Row="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Dialog title text -->
            <TextBlock
                Grid.Column="0"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                Text="{I18N {x:Static l:LangKeys.DictionaryDialogTitle}}" />
            <!-- Search box for filtering backup items -->
            <ui:AutoSuggestBox
                Grid.Column="1"
                VerticalAlignment="Center"
                PlaceholderText="{I18N {x:Static l:LangKeys.SearchBoxPlaceholderText}}">
                <ui:AutoSuggestBox.QueryIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Search}" />
                </ui:AutoSuggestBox.QueryIcon>
            </ui:AutoSuggestBox>
        </Grid>
        <Button Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Margin="0,36,16,0">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Import}" />
                <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.ImportDictionary}}" />
            </StackPanel>
        </Button>
        <TreeView Grid.Row="2" Grid.Column="0" Width="300" Margin="16,16,0,0" BorderThickness="1"
                  BorderBrush="LightGray" ItemTemplateSelector="{StaticResource DictionaryTreeTemplateSelector}"
                  ItemsSource="{Binding DictionaryGroups}">
            <i:Interaction.Behaviors>
                <b:TreeViewSelectedItemBehavior SelectedItem="{}"/>
            </i:Interaction.Behaviors>
        </TreeView>
        <sf:SfDataGrid Grid.Row="2" Grid.Column="1" AutoGenerateColumns="False" Margin="16,16,16,0" ColumnSizer="Star">
            <sf:SfDataGrid.Columns>
                <sf:GridTextColumn HeaderText="原文" />
                <sf:GridTextColumn HeaderText="译文" />
            </sf:SfDataGrid.Columns>
        </sf:SfDataGrid>
        <sf:SfDataPager Grid.Row="3" Grid.Column="1" Margin="0,5" HorizontalAlignment="Center" />
    </Grid>
</Window>