<Window x:Class="Witcher3StringEditor.Dialogs.Views.DictionaryManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:Witcher3StringEditor.Dialogs.ViewModels"
        xmlns:sf="http://schemas.syncfusion.com/wpf"
        xmlns:l="clr-namespace:Witcher3StringEditor.Locales;assembly=Witcher3StringEditor.Locales"
        xmlns:m="clr-namespace:Witcher3StringEditor.Dialogs.Models"
        xmlns:di="clr-namespace:Witcher3StringEditor.Dictionary;assembly=Witcher3StringEditor.Dictionary"
        xmlns:t="clr-namespace:Witcher3StringEditor.Dialogs.TemplateSelectors"
        xmlns:b="clr-namespace:Witcher3StringEditor.Behaviors;assembly=Witcher3StringEditor.Behaviors"
        d:DataContext="{d:DesignInstance Type=vm:DictionaryManagerDialogViewModel}"
        Title="{I18N {x:Static l:LangKeys.DictionaryDialogTitle}}"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        WindowChrome.IsHitTestVisibleInChrome="True"
        Closed="DictionaryDialog_OnClosed"
        mc:Ignorable="d" Width="1200" Height="800">
    <Window.Resources>
        <HierarchicalDataTemplate x:Key="DictionaryGroupTemplate" DataType="{x:Type m:DictionaryGroup}"
                                  ItemsSource="{Binding Dictionaries}">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Folder}" />
                <TextBlock Margin="5,0,0,0" Text="{Binding TargetLanguage.NativeName}" />
            </StackPanel>
        </HierarchicalDataTemplate>
        <DataTemplate x:Key="DictionaryItemTemplate" DataType="{x:Type di:DictionaryInfo}">
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Document}" />
                <TextBlock Margin="5,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Stretch"
                           Text="{Binding Name}" />
            </StackPanel>
        </DataTemplate>
        <t:DictionaryTreeTemplateSelector x:Key="DictionaryTreeTemplateSelector"
                                          DictionaryGroupTemplate="{StaticResource DictionaryGroupTemplate}"
                                          DictionaryItemTemplate="{StaticResource DictionaryItemTemplate}" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Height="48" Grid.Row="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Dialog title text -->
            <TextBlock
                Grid.Column="0"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                Text="{I18N {x:Static l:LangKeys.DictionaryDialogTitle}}" />
            <!-- Search box for filtering backup items -->
            <ui:AutoSuggestBox
                Grid.Column="1"
                VerticalAlignment="Center"
                PlaceholderText="{I18N {x:Static l:LangKeys.SearchBoxPlaceholderText}}"
                QuerySubmitted="SearchBox_OnQuerySubmitted"
                TextChanged="SearchBox_TextChanged">
                <ui:AutoSuggestBox.QueryIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Search}" />
                </ui:AutoSuggestBox.QueryIcon>
            </ui:AutoSuggestBox>
        </Grid>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding ImportDictionaryCommand}">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Import}" />
                    <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.ImportDictionary}}" />
                </StackPanel>
            </Button>
            <Button Margin="16,0" Command="{Binding RemoveDictionaryCommand}"
                    CommandParameter="{Binding SelectedDictionary}">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}" />
                    <TextBlock Margin="5,0,0,0" Text="{I18N {x:Static l:LangKeys.RemoveDictionary}}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <TreeView Grid.Row="2" Grid.Column="0" Width="350" Margin="16,16,0,0"
                  BorderBrush="Gray"
                  BorderThickness="1" ItemTemplateSelector="{StaticResource DictionaryTreeTemplateSelector}"
                  ItemsSource="{Binding DictionaryGroups}">
            <i:Interaction.Behaviors>
                <b:DictionaryTreeSelectionBehavior
                    SelectedItem="{Binding SelectedDictionary,Mode=OneWayToSource}" />
            </i:Interaction.Behaviors>
        </TreeView>
        <sf:SfDataGrid x:Name="SfDataGrid" Grid.Row="2" Grid.Column="1" AutoGenerateColumns="False" Margin="16,16,16,0"
                       ColumnSizer="Star" ItemsSource="{Binding PagedSource, ElementName=SfDataPager}"
                       NavigationMode="Row" ShowRowHeader="True">
            <sf:SfDataGrid.Resources>
                <ResourceDictionary>
                    <Style TargetType="sf:GridRowHeaderCell">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="sf:GridRowHeaderCell">
                                    <Border x:Name="PART_RowHeaderCellBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <Grid>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding RowIndex,RelativeSource={RelativeSource TemplatedParent}}"
                                                       TextAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ResourceDictionary>
            </sf:SfDataGrid.Resources>
            <sf:SfDataGrid.Columns>
                <sf:GridTextColumn MappingName="Key" />
                <sf:GridTextColumn MappingName="Value" />
            </sf:SfDataGrid.Columns>
        </sf:SfDataGrid>
        <sf:SfDataPager x:Name="SfDataPager" Grid.Row="3" Grid.Column="1" Margin="0,5" HorizontalAlignment="Center"
                        Source="{Binding DictionaryTerms}" PageSize="30" NumericButtonCount="10" />
    </Grid>
</Window>